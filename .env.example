# Скопируй в .env и заполни (.env в git не попадает)
# cp .env.example .env   — или вручную на Windows

# Секрет для POST /api/deploy (длинная случайная строка, только лично другу)
DEPLOY_TOKEN=замени_на_длинный_случайный_токен

# После deploy перезапускать app.py --public (нужно для ngrok)
APP_PUBLIC=true

# Токен с https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# Опционально: интервал авто-pull (сек), ветка
# GIT_AUTO_PULL_SECONDS=90
# GIT_AUTO_PULL_BRANCH=main
